    // -----------------------------------------------------------------------
    // APPROVE — move files to 10Web gallery
    // -----------------------------------------------------------------------

    public function approve_submission() {
        check_ajax_referer( 'nmb_nonce', 'nonce' );
        if ( ! current_user_can( 'manage_options' ) ) wp_send_json_error( 'Unauthorized.' );

        $id = intval( $_POST['id'] ?? 0 );
        global $wpdb;
        $table = $wpdb->prefix . 'nmb_pending';

        $row = $wpdb->get_row( $wpdb->prepare( "SELECT * FROM $table WHERE id = %d", $id ) );
        if ( ! $row ) wp_send_json_error( 'Submission not found.' );

        $gallery_id = (int) get_option( 'nmb_gallery_id' );
        if ( ! $gallery_id ) wp_send_json_error( 'Gallery ID not set. Go to Gallery Submissions → Settings.' );

        $files = json_decode( $row->files, true ) ?: [];
        if ( empty( $files ) ) wp_send_json_error( 'No files found in this submission.' );

        $added  = 0;
        $errors = [];

        foreach ( $files as $url ) {
            $result = $this->add_file_to_gallery( $url, $row, $gallery_id );
            if ( $result === true ) {
                $added++;
            } else {
                $errors[] = $result;
            }
        }

        if ( $added > 0 ) {
            $wpdb->update(
                $table,
                [ 'status' => 'approved', 'processed_at' => current_time( 'mysql' ) ],
                [ 'id' => $id ],
                [ '%s', '%s' ],
                [ '%d' ]
            );
            $msg = "$added file(s) added to gallery.";
            if ( ! empty( $errors ) ) $msg .= ' ' . count( $errors ) . ' file(s) failed.';
            wp_send_json_success( $msg );
        } else {
            wp_send_json_error( 'All files failed to process. Errors: ' . implode( ' | ', $errors ) );
        }
    }

    private function add_file_to_gallery( $file_url, $row, $gallery_id ) {
        global $wpdb;

        $upload_dir = wp_upload_dir();
        $base_url   = $upload_dir['baseurl'];
        $base_dir   = $upload_dir['basedir'];

        // Resolve URL to local path
        $file_path = str_replace( $base_url, $base_dir, $file_url );
        $file_path = wp_normalize_path( $file_path );

        if ( ! file_exists( $file_path ) ) {
            return 'File not found on server: ' . basename( $file_path );
        }

        // Determine type
        $ext        = strtolower( pathinfo( $file_path, PATHINFO_EXTENSION ) );
        $img_exts   = [ 'jpg', 'jpeg', 'png', 'gif', 'webp', 'bmp' ];
        $vid_exts   = [ 'mp4', 'mov', 'avi', 'wmv', 'm4v', 'webm' ];
        $filetype   = '';

        if ( in_array( $ext, $img_exts, true ) ) {
            $filetype = 'image';
        } elseif ( in_array( $ext, $vid_exts, true ) ) {
            $filetype = 'video';
        } else {
            return 'Unsupported file type: ' . $ext;
        }

        // 10Web gallery upload directory
        $gallery_dir = $base_dir . '/photo-gallery/';
        if ( ! wp_mkdir_p( $gallery_dir ) ) {
            return 'Cannot create gallery directory.';
        }

        // Unique filename to prevent collisions
        $new_filename = wp_unique_filename( $gallery_dir, 'nmb_' . time() . '_' . sanitize_file_name( basename( $file_path ) ) );
        $dest_path    = $gallery_dir . $new_filename;

        if ( ! copy( $file_path, $dest_path ) ) {
            return 'Failed to copy file: ' . basename( $file_path );
        }

        // Generate thumbnail for images
        $thumb_size = 0;
        if ( $filetype === 'image' ) {
            $thumb_size = $this->make_thumbnail( $dest_path, $gallery_dir, $new_filename );
        }

        // Image resolution
        $resolution = '';
        if ( $filetype === 'image' ) {
            $size_data = getimagesize( $dest_path );
            if ( $size_data ) $resolution = $size_data[0] . 'x' . $size_data[1];
        }

        // Description includes contributor attribution
        $description = 'Contributed by: ' . $row->contributor;
        if ( ! empty( $row->relationship ) ) $description .= ' (' . $row->relationship . ')';
        if ( ! empty( $row->caption ) )      $description .= "\n" . $row->caption;

        // Next sort order in this gallery
        $max_order = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COALESCE(MAX(`order`), -1) FROM {$wpdb->prefix}bwg_image WHERE gallery_id = %d",
            $gallery_id
        ) );
        $next_order = $max_order + 1;

        $inserted = $wpdb->insert(
            $wpdb->prefix . 'bwg_image',
            [
                'gallery_id'         => $gallery_id,
                'filename'           => $new_filename,
                'filetype'           => $filetype,
                'alt'                => $row->contributor,
                'title'              => $row->caption ?: $row->contributor,
                'description'        => $description,
                'date'               => $row->submitted_at,
                'tags'               => '',
                'size'               => (int) filesize( $dest_path ),
                'thumb_size'         => $thumb_size,
                'resolution'         => $resolution,
                'redirect_url'       => '',
                'order'              => $next_order,
                'pricelist_id'       => 0,
                'author'             => 0,
                'comment_count'      => 0,
                'rate'               => 0,
                'show_watermark'     => 0,
                'watermark_position' => 'top-left',
                'hit'                => 0,
            ],
            [ '%d','%s','%s','%s','%s','%s','%s','%s','%d','%d','%s','%s','%d','%d','%d','%d','%d','%d','%s','%d' ]
        );

        if ( $inserted === false ) {
            // Clean up copied file on DB failure
            @unlink( $dest_path );
            return 'Database insert failed for: ' . $new_filename;
        }

        return true;
    }

    private function make_thumbnail( $source_path, $gallery_dir, $filename ) {
        $editor = wp_get_image_editor( $source_path );
        if ( is_wp_error( $editor ) ) return 0;

        $editor->resize( 300, 300, true );
        $thumb_path = $gallery_dir . 'thumb_' . $filename;
        $saved = $editor->save( $thumb_path );

        if ( is_wp_error( $saved ) || ! isset( $saved['path'] ) ) return 0;
        return (int) filesize( $saved['path'] );
    }

    // -----------------------------------------------------------------------
    // REJECT
    // -----------------------------------------------------------------------

    public function reject_submission() {
        check_ajax_referer( 'nmb_nonce', 'nonce' );
        if ( ! current_user_can( 'manage_options' ) ) wp_send_json_error( 'Unauthorized.' );

        $id = intval( $_POST['id'] ?? 0 );
        global $wpdb;

        $wpdb->update(
            $wpdb->prefix . 'nmb_pending',
            [ 'status' => 'rejected', 'processed_at' => current_time( 'mysql' ) ],
            [ 'id' => $id ],
            [ '%s', '%s' ],
            [ '%d' ]
        );

        wp_send_json_success( 'Submission rejected.' );
    }

    // -----------------------------------------------------------------------
    // EMAIL NOTIFICATION
    // -----------------------------------------------------------------------

    private function send_admin_notification( $contributor, $relationship, $file_count ) {
        $to      = get_option( 'nmb_notify_email', get_option( 'admin_email' ) );
        $subject = 'New gallery submission — Nancy Boycan Memorial';

        $body  = "A new gallery submission has arrived and is waiting for your review.\n\n";
        $body .= "Contributor: $contributor";
        if ( ! empty( $relationship ) ) $body .= " ($relationship)";
        $body .= "\nFiles submitted: $file_count\n\n";
        $body .= "Review and approve here:\n";
        $body .= admin_url( 'admin.php?page=nmb-submissions' ) . "\n\n";
        $body .= "— Nancy Memorial Site";

        wp_mail( $to, $subject, $body );
    }
