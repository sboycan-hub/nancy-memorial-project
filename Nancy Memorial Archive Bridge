    // -----------------------------------------------------------------------
    // CAPTURE WPFORMS SUBMISSION
    // -----------------------------------------------------------------------

    public function capture_submission( $fields, $entry, $form_data, $entry_id ) {
        $configured_form = get_option( 'nmb_form_id' );
        if ( empty( $configured_form ) || (int) $form_data['id'] !== (int) $configured_form ) return;

        $fid_contributor  = (int) get_option( 'nmb_field_contributor' );
        $fid_relationship = (int) get_option( 'nmb_field_relationship' );
        $fid_caption      = (int) get_option( 'nmb_field_caption' );
        $fid_files        = (int) get_option( 'nmb_field_files' );

        $contributor  = isset( $fields[ $fid_contributor ]['value'] )  ? sanitize_text_field( $fields[ $fid_contributor ]['value'] )  : '';
        $relationship = isset( $fields[ $fid_relationship ]['value'] ) ? sanitize_text_field( $fields[ $fid_relationship ]['value'] ) : '';
        $caption      = isset( $fields[ $fid_caption ]['value'] )      ? sanitize_textarea_field( $fields[ $fid_caption ]['value'] )  : '';

        // WPForms file upload — value_raw holds array of file URLs for multi-upload
        $file_urls = [];
        if ( isset( $fields[ $fid_files ] ) ) {
            $fdata = $fields[ $fid_files ];
            if ( ! empty( $fdata['value_raw'] ) && is_array( $fdata['value_raw'] ) ) {
                foreach ( $fdata['value_raw'] as $item ) {
                    // Each item may be a URL string or an array with a 'value' key
                    $url = is_array( $item ) ? ( $item['value'] ?? '' ) : $item;
                    if ( ! empty( $url ) ) $file_urls[] = esc_url_raw( $url );
                }
            } elseif ( ! empty( $fdata['value'] ) ) {
                // Single file fallback
                $file_urls[] = esc_url_raw( $fdata['value'] );
            }
        }

        if ( empty( $contributor ) || empty( $file_urls ) ) return;

        $this->maybe_create_table();

        global $wpdb;
        $wpdb->insert(
            $wpdb->prefix . 'nmb_pending',
            [
                'entry_id'     => $entry_id,
                'contributor'  => $contributor,
                'relationship' => $relationship,
                'caption'      => $caption,
                'files'        => wp_json_encode( $file_urls ),
                'status'       => 'pending',
                'submitted_at' => current_time( 'mysql' ),
            ],
            [ '%d', '%s', '%s', '%s', '%s', '%s', '%s' ]
        );

        $this->send_admin_notification( $contributor, $relationship, count( $file_urls ) );
    }

